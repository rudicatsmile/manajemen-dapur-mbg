{
  "name": "manajemen-dapur-mbg",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter frontend --filter backend dev",
    "build": "pnpm --filter shared build && pnpm --parallel --filter frontend --filter backend build",
    "lint": "pnpm --parallel -r lint",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json,css}\"",
    "clean": "pnpm -r exec rm -rf node_modules dist .next .turbo"
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  }
}
